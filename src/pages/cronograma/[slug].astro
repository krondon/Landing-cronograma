---
import CronogramaLayout from '../../layouts/CronogramaLayout.astro';
import { getCronogramaBySlug, getAllCronogramas, formatFecha, formatHora, getPonentesDelDia } from '../../lib/cronogramas';
import type { Actividad, Fecha } from '../../lib/cronogramas';

export async function getStaticPaths() {
  const cronogramas = await getAllCronogramas();
  return cronogramas.map((c) => ({
    params: { slug: c.slug },
  }));
}

const { slug } = Astro.params;
const cronograma = await getCronogramaBySlug(slug!);

if (!cronograma) {
  return Astro.redirect('/404');
}

const {
  nombre,
  descripcion,
  imagen_portada,
  color_primario,
  color_secundario,
  color_fondo,
  color_texto,
  tema,
  cronograma_fechas,
} = cronograma;

const TIPO_LABELS: Record<string, string> = {
  actividad: 'Conferencia',
  receso: 'Receso',
  networking: 'Networking',
  taller: 'Taller',
  panel: 'Panel',
};

const TIPO_COLORS: Record<string, string> = {
  actividad: color_primario,
  receso: '#00FFAB',
  networking: '#F86F03',
  taller: '#8B5CF6',
  panel: color_secundario,
};

const lugar = cronograma_fechas
  .flatMap(f => f.cronograma_actividades)
  .find(a => a.lugar)?.lugar ?? null;

const isClaro = tema === 'claro';

const themeVars = {
  colorPrimario: color_primario,
  colorSecundario: color_secundario,
  colorFondo: color_fondo,
  colorTexto: color_texto,
  
  heroBgGradient: isClaro
    ? 'linear-gradient(145deg, #FFFFFF 0%, #F8FAFC 60%, #F1F5F9 100%)'
    : 'linear-gradient(145deg, #060E1C 0%, #0D1F38 55%, #0B192C 100%)',
    
  glowOpacity: isClaro ? '0.06' : '0.13',
  glowSecondaryOpacity: isClaro ? '0.04' : '0.1',
  
  watermarkStroke: isClaro
    ? '1.5px rgba(15, 23, 42, 0.1)'
    : '1.5px rgba(255, 255, 255, 0.04)',
    
  metaChipBg: isClaro ? 'rgba(15, 23, 42, 0.03)' : 'rgba(255, 255, 255, 0.06)',
  metaChipBorder: isClaro ? 'rgba(15, 23, 42, 0.06)' : 'rgba(255, 255, 255, 0.1)',
  metaChipText: isClaro ? 'rgba(15, 23, 42, 0.6)' : 'rgba(226, 232, 240, 0.7)',
  
  dayCardBg: isClaro ? '#FFFFFF' : 'rgba(255, 255, 255, 0.05)',
  dayCardBorder: isClaro ? 'rgba(15, 23, 42, 0.07)' : 'rgba(255, 255, 255, 0.09)',
  dayCardShadow: isClaro ? '0 4px 20px rgba(15, 23, 42, 0.03)' : 'none',
  
  fechasTabsBg: isClaro ? 'rgba(15, 23, 42, 0.02)' : 'rgba(255, 255, 255, 0.04)',
  fechasTabsBorder: isClaro ? 'rgba(15, 23, 42, 0.05)' : 'rgba(255, 255, 255, 0.08)',
  fechaTabColor: isClaro ? 'rgba(15, 23, 42, 0.55)' : 'rgba(148, 163, 184, 0.8)',
  fechaTabHoverBg: isClaro ? 'rgba(15, 23, 42, 0.03)' : 'rgba(255, 255, 255, 0.06)',
  
  timelineLine: isClaro
    ? 'linear-gradient(to bottom, transparent 0%, rgba(15, 23, 42, 0.06) 8%, rgba(15, 23, 42, 0.06) 92%, transparent 100%)'
    : 'linear-gradient(to bottom, transparent 0%, rgba(255, 255, 255, 0.1) 8%, rgba(255, 255, 255, 0.1) 92%, transparent 100%)',
  timelineTimeColor: isClaro ? 'rgba(15, 23, 42, 0.45)' : 'rgba(148, 163, 184, 0.55)',
  
  actividadCardBg: isClaro ? 'rgba(2, 132, 199, 0.06)' : 'rgba(255, 255, 255, 0.04)',
  actividadCardBorder: isClaro ? 'rgba(2, 132, 199, 0.14)' : 'rgba(255, 255, 255, 0.07)',
  cardShadow: isClaro ? '0 4px 18px rgba(2, 132, 199, 0.03)' : '0 2px 12px rgba(0, 0, 0, 0.25)',
  
  textHeadingColor: isClaro ? '#0F172A' : '#E2E8F0',
  textDescColor: isClaro ? '#475569' : 'rgba(148, 163, 184, 0.75)',
  cardBodyBgHover: isClaro ? 'rgba(2, 132, 199, 0.1)' : 'rgba(255, 255, 255, 0.07)',
  
  badgeActividadBg: isClaro ? 'rgba(2, 132, 199, 0.1)' : 'rgba(255, 255, 255, 0.06)',
  badgeActividadColor: isClaro ? '#0284C7' : 'var(--colorPrimario)',
  badgeActividadBorder: isClaro ? 'rgba(2, 132, 199, 0.18)' : 'rgba(255, 255, 255, 0.12)',
  
  badgeRecesoBg: isClaro ? 'rgba(16, 185, 129, 0.1)' : 'rgba(0, 255, 171, 0.12)',
  badgeRecesoColor: isClaro ? '#059669' : '#00FFAB',
  badgeRecesoBorder: isClaro ? 'rgba(16, 185, 129, 0.18)' : 'rgba(0, 255, 171, 0.2)',
  
  badgeNetworkingBg: isClaro ? 'rgba(249, 115, 22, 0.1)' : 'rgba(248, 111, 3, 0.15)',
  badgeNetworkingColor: isClaro ? '#EA580C' : '#FF8C35',
  badgeNetworkingBorder: isClaro ? 'rgba(249, 115, 22, 0.18)' : 'rgba(248, 111, 3, 0.25)',
  
  badgeTallerBg: isClaro ? 'rgba(139, 92, 246, 0.1)' : 'rgba(139, 92, 246, 0.15)',
  badgeTallerColor: isClaro ? '#7C3AED' : '#A78BFA',
  badgeTallerBorder: isClaro ? 'rgba(139, 92, 246, 0.18)' : 'rgba(139, 92, 246, 0.25)',
  
  badgePanelBg: isClaro ? 'rgba(236, 72, 153, 0.1)' : 'rgba(168, 85, 247, 0.15)',
  badgePanelColor: isClaro ? '#DB2777' : '#C084FC',
  badgePanelBorder: isClaro ? 'rgba(236, 72, 153, 0.18)' : 'rgba(168, 85, 247, 0.25)',
  
  speakerChipBg: isClaro ? 'rgba(15, 23, 42, 0.03)' : 'rgba(255, 255, 255, 0.06)',
  speakerChipBorder: isClaro ? 'rgba(15, 23, 42, 0.06)' : 'rgba(255, 255, 255, 0.1)',
  speakerChipText: isClaro ? '#334155' : '#E2E8F0',
  speakerChipHoverBg: isClaro ? 'rgba(2, 132, 199, 0.08)' : 'rgba(255, 255, 255, 0.08)',
  
  titleDecorColor: isClaro ? 'rgba(15, 23, 42, 0.07)' : 'rgba(255, 255, 255, 0.07)',
  
  footerBg: isClaro ? 'rgba(15, 23, 42, 0.02)' : 'rgba(6, 14, 28, 0.4)',
  footerBorder: isClaro ? 'rgba(15, 23, 42, 0.06)' : 'rgba(255, 255, 255, 0.06)',
  footerLogoFilter: isClaro ? 'none' : 'brightness(0) invert(1)',
  footerLogoOpacity: isClaro ? '0.85' : '0.7',
};

const maxActividades = Math.max(
  ...cronograma_fechas.map(f => f.cronograma_actividades.length), 1
);
---

<CronogramaLayout
  title={nombre}
  description={descripcion ?? ''}
  ogImage={imagen_portada ?? ''}
  colorFondo={color_fondo}
  colorTexto={color_texto}
  colorPrimario={color_primario}
>
  <style define:vars={themeVars}>

    /* ── TOP BAR ── */
    .top-bar {
      height: 3px;
      background: linear-gradient(90deg, var(--colorPrimario) 0%, var(--colorSecundario) 100%);
      position: relative;
      z-index: 10;
    }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 480px;
      padding: 4rem 2rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: var(--heroBgGradient);
    }
    .hero-bg.has-image {
      background-size: cover;
      background-position: center;
    }
    /* Dot grid */
    .hero-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(255,255,255,0.09) 1px, transparent 1px);
      background-size: 28px 28px;
      z-index: 1;
    }
    .hero-bg.has-image::before { display: none; }
    /* Bottom fade */
    .hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 50%, var(--colorFondo) 100%);
      z-index: 2;
    }
    /* Animated glow — primary color */
    .hero-glow-primary {
      position: absolute;
      width: 480px; height: 480px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--colorPrimario) 0%, transparent 68%);
      opacity: var(--glowOpacity);
      filter: blur(70px);
      top: -120px; right: 80px;
      z-index: 1; pointer-events: none;
      animation: glowBreath 7s ease-in-out infinite;
    }
    /* Animated glow — secondary color */
    .hero-glow-secondary {
      position: absolute;
      width: 380px; height: 380px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--colorSecundario) 0%, transparent 68%);
      opacity: var(--glowSecondaryOpacity);
      filter: blur(90px);
      bottom: -60px; left: 5%;
      z-index: 1; pointer-events: none;
      animation: glowBreath 9s ease-in-out infinite;
      animation-delay: -4s;
    }
    @keyframes glowBreath {
      0%, 100% { opacity: 0.1; transform: scale(1); }
      50%       { opacity: 0.22; transform: scale(1.18); }
    }
    /* Giant watermark year */
    .hero-watermark {
      position: absolute;
      right: -30px; bottom: -50px;
      font-family: 'Syne', sans-serif;
      font-size: clamp(10rem, 22vw, 18rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.06em;
      color: transparent;
      -webkit-text-stroke: var(--watermarkStroke);
      user-select: none; pointer-events: none;
      z-index: 1;
    }
    /* Horizontal accent line */
    .hero-accent-line {
      position: absolute;
      left: 0; right: 0; top: 0;
      height: 1px;
      background: linear-gradient(90deg,
        transparent 0%,
        var(--colorPrimario) 30%,
        var(--colorSecundario) 70%,
        transparent 100%
      );
      opacity: 0.35;
    }

    /* ── HERO LEFT CONTENT ── */
    .hero-content {
      position: relative;
      z-index: 3;
      flex: 1 1 400px;
      animation: heroEnter 0.6s cubic-bezier(0.2,0,0,1) both;
    }
    @keyframes heroEnter {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--metaChipBg);
      backdrop-filter: blur(12px);
      border: 1px solid var(--metaChipBorder);
      padding: 0.5rem 1.2rem;
      border-radius: 50px;
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--metaChipText);
      margin-bottom: 2rem;
    }
    .hero-badge-dot {
      width: 9px; height: 9px;
      border-radius: 50%;
      background: #00FFAB;
      box-shadow: 0 0 10px #00FFAB, 0 0 20px rgba(0,255,171,0.4);
      animation: blink 2s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }
    .hero-title {
      font-family: 'Syne', sans-serif;
      font-size: 6vw;
      font-size: clamp(3rem, 6vw, 4.8rem);
      font-weight: 800;
      color: var(--textHeadingColor);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    /* Highlighted last word of title */
    .hero-title-accent {
      background: linear-gradient(95deg, var(--colorPrimario) 0%, #059669 50%, var(--colorSecundario) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero-desc {
      font-family: 'Outfit', sans-serif;
      font-size: 1.1rem;
      color: var(--metaChipText);
      max-width: 600px;
      line-height: 1.7;
    }
    /* Meta chips row */
    .hero-meta {
      display: flex;
      gap: 0.8rem;
      flex-wrap: wrap;
      margin-top: 2rem;
    }
    .meta-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--metaChipBg);
      border: 1px solid var(--metaChipBorder);
      border-radius: 50px;
      padding: 0.5rem 1.1rem;
      font-family: 'Outfit', sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--metaChipText);
      backdrop-filter: blur(8px);
    }
    .meta-chip-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--colorPrimario);
      flex-shrink: 0;
    }

    /* ── RESPONSIVE HERO ── */
    @media (max-width: 860px) {
      .hero {
        padding: 3.5rem 1.5rem 3rem;
        min-height: 380px;
        gap: 2rem;
      }
      .hero-watermark { 
        font-size: 20vw;
        font-size: clamp(5.5rem, 26vw, 10rem);
        bottom: 4rem;
        right: -10px;
      }
    }
    @media (max-width: 540px) {
      .hero { padding: 3rem 1rem 2.5rem; }
      .hero-title { font-size: 9vw; font-size: clamp(1.8rem, 8vw, 2.6rem); }
      .hero-watermark { bottom: 5rem; }
    }

    /* ── MAIN ── */
    .main {
      max-width: 900px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 5rem;
    }

    /* ── TABS ── */
    .fechas-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 2.75rem;
      background: var(--fechasTabsBg);
      border: 1px solid var(--fechasTabsBorder);
      border-radius: 16px;
      padding: 4px;
      backdrop-filter: blur(12px);
    }
    .fecha-tab {
      flex: 1;
      padding: 0.7rem 0.75rem;
      border-radius: 12px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      background: transparent;
      color: var(--fechaTabColor);
      transition: all 0.22s;
      text-align: center;
      text-transform: capitalize;
      letter-spacing: 0.01em;
    }
    .fecha-tab:hover {
      color: var(--textHeadingColor);
      background: var(--fechaTabHoverBg);
    }
    .fecha-tab.active {
      background: var(--colorPrimario);
      color: #fff;
      box-shadow: 0 4px 16px rgba(15, 23, 42, 0.15), 0 0 12px var(--colorPrimario);
    }

    /* ── PANELS ── */
    .fecha-panel { display: none; }
    .fecha-panel.active { display: block; }

    /* ── TIMELINE ── */
    .actividades-list {
      display: flex;
      flex-direction: column;
      position: relative;
      gap: 0;
    }
    .actividades-list::before {
      content: '';
      position: absolute;
      left: 68px;
      top: 12px;
      bottom: 12px;
      width: 1px;
      background: var(--timelineLine);
      pointer-events: none;
    }
    .actividad-card {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 0.6rem 0;
      position: relative;
    }
    .actividad-card[data-has-ponentes="true"] { cursor: pointer; }
    .actividad-card::before {
      content: '';
      position: absolute;
      left: 68px;
      top: 1.05rem;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--colorPrimario);
      border: 2px solid var(--colorFondo);
      box-shadow: 0 0 0 2px var(--colorPrimario), 0 0 8px var(--colorPrimario);
      transform: translateX(-50%);
      z-index: 2;
    }
    .actividad-hora {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      padding-top: 0.8rem;
      padding-right: 10px;
      width: 68px;
      flex-shrink: 0;
    }
    .hora-text {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--colorPrimario);
      line-height: 1.2;
      text-align: right;
    }
    .hora-fin {
      font-size: 0.9rem;
      color: var(--timelineTimeColor);
      text-align: right;
      margin-top: 2px;
    }

    /* Glass activity card */
    .actividad-body {
      flex: 1;
      min-width: 0;
      background: var(--actividadCardBg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--actividadCardBorder);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
      position: relative;
      overflow: hidden;
      box-shadow: var(--cardShadow);
    }
    .actividad-body::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 4px;
      border-radius: 4px 0 0 4px;
      background: var(--tipo-color);
      box-shadow: 0 0 8px var(--tipo-color)88;
    }
    .actividad-card[data-has-ponentes="true"]:hover .actividad-body {
      border-color: var(--colorPrimario);
      background: var(--cardBodyBgHover);
      box-shadow: 0 8px 28px rgba(15, 23, 42, 0.08), 0 0 0 1px var(--colorPrimario);
      transform: translateX(4px);
    }

    .actividad-header {
      display: flex;
      align-items: flex-start;
      gap: 0.8rem;
      flex-wrap: wrap;
      margin-bottom: 0.5rem;
    }
    .actividad-titulo {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--textHeadingColor);
      line-height: 1.35;
      flex: 1;
      min-width: 0;
    }
    .tipo-badge {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.25rem 0.65rem;
      border-radius: 50px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      flex-shrink: 0;
      margin-top: 3px;
    }
    .tipo-actividad  { background: var(--badgeActividadBg);  color: var(--badgeActividadColor); border: 1px solid var(--badgeActividadBorder); }
    .tipo-receso     { background: var(--badgeRecesoBg);     color: var(--badgeRecesoColor); border: 1px solid var(--badgeRecesoBorder); }
    .tipo-networking { background: var(--badgeNetworkingBg); color: var(--badgeNetworkingColor); border: 1px solid var(--badgeNetworkingBorder); }
    .tipo-taller     { background: var(--badgeTallerBg);     color: var(--badgeTallerColor); border: 1px solid var(--badgeTallerBorder); }
    .tipo-panel      { background: var(--badgePanelBg);      color: var(--badgePanelColor); border: 1px solid var(--badgePanelBorder); }

    .actividad-desc {
      font-size: 1.05rem;
      color: var(--textDescColor);
      line-height: 1.6;
      margin-top: 0.4rem;
    }
    .actividad-lugar {
      font-size: 0.95rem;
      color: var(--timelineTimeColor);
      margin-top: 0.5rem;
    }

    /* ── SPEAKER CHIPS ── */
    .ponentes-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin-top: 0.8rem;
    }
    .ponente-chip {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      background: var(--speakerChipBg);
      border: 1px solid var(--speakerChipBorder);
      border-radius: 50px;
      padding: 0.28rem 0.75rem 0.28rem 0.3rem;
      font-size: 0.78rem;
      transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
      cursor: pointer;
      color: var(--speakerChipText);
    }
    .ponente-chip:hover {
      background: var(--speakerChipHoverBg);
      border-color: var(--colorPrimario);
      box-shadow: 0 0 12px var(--colorPrimario);
    }
    .ponente-chip img {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      object-fit: cover;
    }
    .ponente-chip-avatar {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--colorPrimario), var(--colorSecundario));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.62rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .ponente-chip-name  { font-weight: 600; color: var(--textHeadingColor); }
    .ponente-chip-cargo { color: var(--timelineTimeColor); }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: rgba(148,163,184,0.5);
    }

    /* ── INFINITE SPEAKERS CAROUSEL (LARGE POSTER CARDS) ── */
    .ponentes-marquee-section {
      margin-bottom: 3rem;
      position: relative;
      overflow: hidden;
      width: 100%;
      padding: 0.5rem 0;
    }
    .ponentes-marquee-title {
      font-size: 0.68rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--colorPrimario);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0 0.25rem;
    }
    .ponentes-marquee-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--titleDecorColor);
    }
    .marquee-container {
      position: relative;
      width: 100%;
      overflow-x: auto;
      scrollbar-width: none; /* Hide scrollbar in Firefox */
      display: flex;
      mask-image: linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, #000 12%, #000 88%, transparent 100%);
    }
    .marquee-container::-webkit-scrollbar {
      display: none; /* Hide scrollbar in Chrome/Safari */
    }
    .single-ponente-container {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      padding: 1rem 0;
    }
    .marquee-track {
      display: flex;
      width: max-content;
      /* Scroll to the left */
      animation: marqueeScroll 20s linear infinite;
    }
    .marquee-track:hover {
      animation-play-state: paused;
    }
    .marquee-group {
      display: flex;
      gap: 1.5rem;
      padding-right: 1.5rem;
      flex-shrink: 0;
    }
