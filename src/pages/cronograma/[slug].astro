  <script is:inline>
    (function() {
      function esc(s) {
        if (!s) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function photoOrInitial(fotoUrl, nombre, cls) {
        if (fotoUrl) {
          return '<img src="' + esc(fotoUrl) + '" alt="' + esc(nombre) + '" />';
        } else {
          var initial = nombre ? String(nombre).charAt(0).toUpperCase() : '';
          return '<div class="' + cls + '">' + initial + '</div>';
        }
      }

      function openModal(titulo, ponentes) {
        var backdrop = document.getElementById('ponente-modal');
        var panel = document.getElementById('modal-panel');
        if (!backdrop || !panel) return;
        if (!ponentes || !ponentes.length) return;

        var html = '';
        if (ponentes.length === 1) {
          var p = ponentes[0];
          if (p.foto_url) {
            html = '<div class="modal-photo-area">' +
                   '<img src="' + esc(p.foto_url) + '" alt="' + esc(p.nombre) + '" />' +
                   '<button class="modal-close js-close">✕</button>' +
                   '</div>';
          } else {
            var initial = p.nombre ? String(p.nombre).charAt(0).toUpperCase() : '';
            html = '<div class="modal-photo-area" style="height:240px">' +
                   '<div class="modal-photo-inicial">' + initial + '</div>' +
                   '<button class="modal-close js-close">✕</button>' +
                   '</div>' +
                   '<div class="modal-info">' +
                   '<p class="modal-activity-label">' + esc(titulo) + '</p>' +
                   '<p style="font-size:1.3rem;font-weight:800;color:#E2E8F0;margin-bottom:0.4rem">' + esc(p.nombre) + '</p>' +
                   (p.cargo ? '<p class="modal-cargo">' + esc(p.cargo) + '</p>' : '') +
                   (p.empresa ? '<p class="modal-empresa">' + esc(p.empresa) + '</p>' : '') +
                   ((p.cargo || p.empresa) ? '<div class="modal-divider"></div>' : '') +
                   (p.bio ? '<p class="modal-bio">' + esc(p.bio) + '</p>' : '') +
                   '</div>';
          }
        } else {
          var items = '';
          for (var i = 0; i < ponentes.length; i++) {
            var p = ponentes[i];
            items += '<div class="modal-ponente-item">' +
                     '<div class="modal-ponente-avatar">' +
                     photoOrInitial(p.foto_url, p.nombre, 'modal-ponente-avatar-inicial') +
                     '</div>' +
                     '<div>' +
                     '<p class="modal-ponente-name">' + esc(p.nombre) + '</p>' +
                     (p.cargo ? '<p class="modal-ponente-cargo">' + esc(p.cargo) + '</p>' : '') +
                     '</div>' +
                     '</div>';
          }
          html = '<div class="modal-multi-header">' +
                 '<span class="modal-multi-title">' + esc(titulo) + '</span>' +
                 '<button class="modal-close-flat js-close">✕</button>' +
                 '</div>' +
                 '<div class="modal-info">' + items + '</div>';
        }

        panel.innerHTML = html;
        if (backdrop.className.indexOf('open') === -1) {
          backdrop.className += ' open';
        }

        var closeBtns = panel.querySelectorAll('.js-close');
        for (var i = 0; i < closeBtns.length; i++) {
          closeBtns[i].onclick = closeModal;
          closeBtns[i].ontouchstart = closeModal;
        }
      }

      function closeModal(e) {
        if (e && e.preventDefault) e.preventDefault();
        var backdrop = document.getElementById('ponente-modal');
        if (backdrop) {
          backdrop.className = backdrop.className.replace(' open', '');
        }
      }

      // ── Attach Events Directly and IMMEDIATELY ──

      // 1. Tabs
      var tabs = document.querySelectorAll('.fecha-tab');
      var panels = document.querySelectorAll('.fecha-panel');
      for (var i = 0; i < tabs.length; i++) {
        var tabHandler = function(e) {
          if (e && e.preventDefault) e.preventDefault();
          var tab = e.currentTarget || this;
          var idx = tab.getAttribute('data-index');
          for (var j = 0; j < tabs.length; j++) { tabs[j].className = tabs[j].className.replace(' active', ''); }
          for (var j = 0; j < panels.length; j++) { panels[j].className = panels[j].className.replace(' active', ''); }
          tab.className += ' active';
          var panelActivo = document.querySelector('.fecha-panel[data-index="' + idx + '"]');
          if (panelActivo) {
            panelActivo.className += ' active';
          }
        };
        tabs[i].onclick = tabHandler;
        tabs[i].ontouchstart = tabHandler;
      }

      // 2. Actividad Cards
      var cards = document.querySelectorAll('.actividad-card[data-has-ponentes="true"]');
      for (var i = 0; i < cards.length; i++) {
        var cardHandler = function(e) {
          if (e && e.preventDefault) e.preventDefault();
          var card = e.currentTarget || this;
          var titulo = card.getAttribute('data-titulo') || '';
          var ponentesRaw = card.getAttribute('data-ponentes') || '[]';
          var ponentes = [];
          try { ponentes = JSON.parse(ponentesRaw); } catch(err) {}
          openModal(titulo, ponentes);
        };
        cards[i].onclick = cardHandler;
        cards[i].ontouchstart = cardHandler;
      }

      // 3. Ponente Marquee Cards
      var pCards = document.querySelectorAll('.ponente-marquee-card[data-ponente]');
      for (var i = 0; i < pCards.length; i++) {
        var pCardHandler = function(e) {
          if (e && e.preventDefault) e.preventDefault();
          var card = e.currentTarget || this;
          var pRaw = card.getAttribute('data-ponente') || '{}';
          var p = {};
          try { p = JSON.parse(pRaw); } catch(err) {}
          openModal(p.cargo || '', [p]);
        };
        pCards[i].onclick = pCardHandler;
        pCards[i].ontouchstart = pCardHandler;
      }

      // 4. Modal Backdrop
      var backdrop = document.getElementById('ponente-modal');
      if (backdrop) {
        var backdropHandler = function(e) {
          if (e.target === backdrop) {
            if (e && e.preventDefault) e.preventDefault();
            closeModal();
          }
        };
        backdrop.onclick = backdropHandler;
        backdrop.ontouchstart = backdropHandler;
      }

      document.onkeydown = function(e) { if (e.key === 'Escape' || e.keyCode === 27) closeModal(); };

    })();
  </script>
</CronogramaLayout>
